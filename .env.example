# Copy to .env on the server if your host supports environment files.
# Most cPanel/Plesk Node.js panels also expose these in the UI.

NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Memory limit for Node.js (2 GB RAM host — leave headroom for the OS).
NODE_OPTIONS=--max-old-space-size=1536

# Single-core optimization.
UV_THREADPOOL_SIZE=2

# Disable Next.js telemetry.
NEXT_TELEMETRY_DISABLED=1
